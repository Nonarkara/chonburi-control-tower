{
  "name": "chonburi-control-tower",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter @chonburi/web dev",
    "dev:api": "pnpm --filter @chonburi/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "deploy:web": "pnpm --filter @chonburi/web build && pnpm --filter @chonburi/web deploy",
    "deploy:api": "pnpm --filter @chonburi/api deploy"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  }
}
