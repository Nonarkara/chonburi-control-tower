<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>org.nonarkara.chonburi-api</string>

    <key>WorkingDirectory</key>
    <string>/Users/nonarkara/Projects/dashboards/Chonburi/apps/api</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/caffeinate</string>
        <string>-is</string>
        <string>/Users/nonarkara/Library/pnpm/pnpm</string>
        <string>start:node</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/bin:/bin:/Users/nonarkara/Library/pnpm:/Users/nonarkara/.local/bin</string>
        <key>HOST</key>
        <string>127.0.0.1</string>
        <key>PORT</key>
        <string>8787</string>
        <key>ENVIRONMENT</key>
        <string>production</string>
        <!-- GEMINI_API_KEY is injected into the live plist at
             ~/Library/LaunchAgents/org.nonarkara.chonburi-api.plist (not committed). -->
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/Users/nonarkara/Projects/dashboards/Chonburi/var/api.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/nonarkara/Projects/dashboards/Chonburi/var/api.err.log</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
