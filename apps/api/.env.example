# CTM-01 API local environment

# Supabase / Postgres persistence for the semantic city twin.
# Paste the Supabase Transaction Pooler connection string here, or use
# DATABASE_URL if you prefer a generic Postgres name.
SUPABASE_DB_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# Supabase requires SSL. The API auto-enables SSL for Supabase hosts; keep this
# explicit if your connection string uses a custom host or proxy.
DATABASE_SSL=true

# Keep this small for Supabase pooler friendliness.
DATABASE_POOL_MAX=3

# Optional service keys used by other adapters.
# GEMINI_API_KEY=
# AISSTREAM_TOKEN=
# FACEBOOK_PAGE_ID=
# FACEBOOK_PAGE_TOKEN=
# FMP_API_KEY=
# FRED_API_KEY=
# DATA_GO_TH_TOKEN=
